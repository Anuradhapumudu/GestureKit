<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist — GestureKit
  Embedded into the app bundle by SwiftPM via the resources directive.
  Key entries:
    LSUIElement = YES           → Hides the Dock icon (menu bar app).
    NSAccessibilityUsageDescription → System prompt explaining why we need Accessibility.
    NSAppleEventsUsageDescription   → For AppleScript execution.
-->
<plist version="1.0">
<dict>
    <!-- App identity -->
    <key>CFBundleName</key>
    <string>GestureKit</string>
    <key>CFBundleDisplayName</key>
    <string>GestureKit</string>
    <key>CFBundleIdentifier</key>
    <string>com.gesturekit.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleExecutable</key>
    <string>GestureKit</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Minimum macOS version: 13 Ventura -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Hide from Dock — menu bar app only -->
    <key>LSUIElement</key>
    <true/>

    <!-- Privacy usage descriptions (required for notarisation) -->
    <key>NSAccessibilityUsageDescription</key>
    <string>GestureKit needs Accessibility access to intercept trackpad gestures system-wide. No data is recorded or sent anywhere.</string>

    <key>NSAppleEventsUsageDescription</key>
    <string>GestureKit can run AppleScript actions that you configure. Scripts only run when you trigger a gesture.</string>

    <!-- Supports both light and dark mode -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>

    <!-- High-resolution display support -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- App category for Mac App Store (if distributed there) -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
</dict>
</plist>
